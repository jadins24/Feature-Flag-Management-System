# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Server
PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRATION=7d

# CORS
CORS_ORIGIN=http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004

# Database (used by migrate & test-connection scripts)
DATABASE_URL=postgresql://user:password@localhost:5432/feature_flags

# Super Admin seed credentials
SUPER_ADMIN_EMAIL=admin@featureflags.com
SUPER_ADMIN_PASSWORD=change-this-password
